generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
                
model Booking { 
  id            Int       @id @default(autoincrement())
  listingId     Int
  checkIn       String
  checkOut      String
  guests        Int
  totalPrice    Float
  status        String    @default("confirmed")
  createdAt     DateTime  @default(now())

  listing       Listing   @relation(fields: [listingId], references: [id])
}

model Listing {
  id            Int       @id @default(autoincrement())
  title         String
  location      String
  price         Float
  rating        Float
  imageUrl      String
  startDate     String
  endDate       String
  googleMapsUrl String
  isSuperhost   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  bookings      Booking[]
}               
