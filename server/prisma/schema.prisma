generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Listing {
  id            Int       @id @default(autoincrement())
  title         String
  location      String
  price         Float
  rating        Float
  imageUrl      String
  startDate     String
  endDate       String
  googleMapsUrl String
  isSuperhost   Boolean   @default(false)
  createdAt     DateTime  @default(now())
}
